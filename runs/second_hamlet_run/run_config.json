{
  "document_path": "hamlet.txt",
  "chunks_path": "data/hamlet_chunks.jsonl",
  "questions_path": "data/hamlet_questions.json",
  "output_dir": "runs",
  "run_name": "qwen_hamlet_probe",
  "tokenizer_model": "Qwen/Qwen3.5-9B",
  "reader_model": "Qwen/Qwen3.5-9B",
  "embedding_model": "Qwen/Qwen3-Embedding-8B",
  "reranker_model": "Qwen/Qwen3-Reranker-8B",
  "temperature": 0.0,
  "max_new_tokens": 512,
  "chunk_size": 256,
  "chunk_overlap": 64,
  "context_budgets": [
    1000
  ],
  "treatments": [
    "closed_book",
    "gold_evidence",
    "dense_reranked",
    "dense_document_order",
    "dense_random_order",
    "sparse_bm25"
  ],
  "top_k": 50,
  "random_seed": 13,
  "gpu_layout": "a40-3gpu",
  "embedding_batch_size": 64,
  "embedding_device": "cuda:0",
  "reranker_batch_size": 8,
  "reranker_device": "cuda:1",
  "reader_device": "cuda:2",
  "bm25_k1": 1.5,
  "bm25_b": 0.75,
  "tensor_parallel_size": 1,
  "gpu_memory_utilization": 0.9,
  "prepare_only": false,
  "overwrite": true
}
