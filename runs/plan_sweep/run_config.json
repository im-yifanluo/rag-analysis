{
  "document_path": "data/hamlet.txt",
  "chunks_path": "data/hamlet_chunks.jsonl",
  "questions_path": "data/hamlet_questions.json",
  "output_dir": "runs",
  "run_name": "plan_sweep",
  "tokenizer_model": "Qwen/Qwen3.5-9B",
  "reader_model": "Qwen/Qwen3.5-9B",
  "embedding_model": "Qwen/Qwen3-Embedding-8B",
  "reranker_model": "Qwen/Qwen3-Reranker-8B",
  "temperature": 0.0,
  "max_new_tokens": 512,
  "chunk_size": 256,
  "chunk_overlap": 64,
  "context_budgets": [
    1000
  ],
  "treatments": [
    "plan_fixed_subq_par",
    "plan_fixed_subq_seq",
    "plan_fixed_inforeq_par",
    "plan_fixed_inforeq_seq",
    "plan_fixed_strategy_par",
    "plan_fixed_strategy_seq",
    "plan_dynamic_contract",
    "plan_dynamic_strategy"
  ],
  "top_k": 50,
  "random_seed": 13,
  "gpu_layout": "single",
  "embedding_batch_size": 64,
  "embedding_device": "cuda:0",
  "reranker_batch_size": 8,
  "reranker_device": "cuda:1",
  "reader_device": "cuda:2",
  "bm25_k1": 1.5,
  "bm25_b": 0.75,
  "domain_kg_path": "data/hamlet_domain_kg.yaml",
  "context_assembly_cache_dir": "data/cache",
  "setr_max_passages": 50,
  "setr_selector_max_tokens": 4096,
  "crag_ndocs": 10,
  "crag_upper_threshold": 2.5,
  "crag_lower_threshold": 0.875,
  "crag_decompose_mode": "excerption",
  "crag_external_top_k": 5,
  "crag_evaluator_device": null,
  "macrag_artifacts_dir": "data/macrag",
  "macrag_top_k1": 100,
  "macrag_top_k2": 7,
  "macrag_chunk_ext": 1,
  "macrag_merge_version": 1,
  "recomp_extractive_model": "fangyuan/hotpotqa_extractive_compressor",
  "recomp_abstractive_model": "fangyuan/hotpotqa_abstractive",
  "recomp_abstractive_mode": "t5",
  "recomp_input_docs": 5,
  "recomp_top_sentences": 5,
  "support_candidate_chunks": 30,
  "support_node_candidate_catalog_k": 20,
  "support_max_nodes": 5,
  "support_teacher_units_per_node": 12,
  "support_unit_types": "chunk,sentence,line_span,neighbor_left,neighbor_right",
  "support_include_neighbors": true,
  "support_neighbor_hops": 1,
  "support_max_units_total": 200,
  "support_max_unit_tokens": 512,
  "support_node_coverage_threshold": 0.85,
  "support_redundancy_beta": 0.15,
  "support_token_exponent_tau": 0.7,
  "support_min_unit_score": 0.45,
  "support_max_selected_units": 8,
  "support_node_induction_max_tokens": 1024,
  "support_teacher_max_tokens": 384,
  "support_prompt_order": "anchor_then_node_doc_order",
  "support_score_cache_path": "data/cache/reader_support_cache.json",
  "plan_decomp_prompt": "info_requirements",
  "plan_planner_prompt": "contract_v1",
  "plan_followup_prompt": "rewrite_with_evidence",
  "plan_retrieval_mode": "parallel",
  "plan_support_policy": "reranker",
  "plan_selection_policy": "greedy_coverage",
  "plan_ordering_policy": "document_order",
  "plan_node_top_k": 10,
  "plan_max_nodes": 5,
  "plan_catalog_k": 20,
  "plan_min_support": 0.5,
  "plan_support_temp": 1.0,
  "plan_coverage_threshold": 0.85,
  "plan_redundancy_beta": 0.15,
  "plan_token_exponent_tau": 0.7,
  "plan_max_selected_units": 8,
  "plan_llm_max_tokens": 1024,
  "plan_followup_max_tokens": 256,
  "plan_teacher_max_tokens": 384,
  "plan_cache_path": "data/cache/evidence_plan_cache.json",
  "tensor_parallel_size": 1,
  "gpu_memory_utilization": 0.9,
  "prepare_only": false,
  "overwrite": true
}
